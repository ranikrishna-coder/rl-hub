# AgentWork Simulator — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Jira Integration (required for Jira RL environments)
JIRA_BASE_URL=https://rlhub.atlassian.net/
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=KAN
JIRA_SUBTASK_ISSUE_TYPE_NAME=subtask,task,story
JIRA_USE_LIVE_FOR_TRAINING=true

# To create a Jira API token:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Paste the token above

# ---------------------------------------------------------------------------
# MariaDB — persistence for environments, scenarios, verifiers, contact form
# Create the database before first run: CREATE DATABASE IF NOT EXISTS agentwork_simulator;
# ---------------------------------------------------------------------------
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=agentwork
MARIADB_PASSWORD=your-password
MARIADB_DATABASE=agentwork_simulator
